<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <!-- Base Vector Drawable -->
    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="24"
            android:viewportHeight="24">

            <!-- Background glowing disk (behind the robot, centered at X=12, Y=12) -->
            <group android:name="ambient_glow">
                <path
                    android:fillColor="#FF00E676"
                    android:pathData="M12,12m-11,0a11,11 0,1 1,22 0a11,11 0,1 1,-22 0" />
            </group>

            <!-- Robot Head base structure -->
            <path
                android:fillColor="#FFFFFFFF"
                android:pathData="M5,10c0,-3 2,-5 7,-5c5,0 7,2 7,5v5c0,1.1 -0.9,2 -2,2h-10c-1.1,0 -2,-0.9 -2,-2v-5z" />
            
            <!-- Antennas -->
            <path
                android:fillColor="#FF00E676"
                android:pathData="M8,5L6,2l1,-1l2,3z" />
            <path
                android:fillColor="#FF00E676"
                android:pathData="M16,5l2,-3l-1,-1l-2,3z" />
            
            <!-- Outer ears -->
            <path
                android:fillColor="#FF00E676"
                android:pathData="M4,10h1v4h-1z" />
            <path
                android:fillColor="#FF00E676"
                android:pathData="M19,10h1v4h-1z" />

            <!-- Original Black Eyes (underneath glowing layers) -->
            <path
                android:fillColor="#FF121212"
                android:pathData="M9,10m-1,0a1,1 0,1 1,2 0a1,1 0,1 1,-2 0" />
            <path
                android:fillColor="#FF121212"
                android:pathData="M15,10m-1,0a1,1 0,1 1,2 0a1,1 0,1 1,-2 0" />

            <!-- Original Black Mouth -->
            <path
                android:fillColor="#FF121212"
                android:pathData="M9,13.5h6v1.5h-6z" />

            <!-- Glowing eyes and mouth (Cyan/Green neon face) overlay -->
            <group android:name="glowing_face">
                <!-- Glowing Cyan Eyes -->
                <path
                    android:fillColor="#FF00FFFF"
                    android:pathData="M9,10m-1,0a1,1 0,1 1,2 0a1,1 0,1 1,-2 0" />
                <path
                    android:fillColor="#FF00FFFF"
                    android:pathData="M15,10m-1,0a1,1 0,1 1,2 0a1,1 0,1 1,-2 0" />
                <!-- Glowing Cyan Mouth -->
                <path
                    android:fillColor="#FF00FFFF"
                    android:pathData="M9,13.5h6v1.5h-6z" />
            </group>

        </vector>
    </aapt:attr>

    <!-- Target for Ambient Glow Breathing Animation (Background disk) -->
    <target android:name="ambient_glow">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="alpha"
                android:duration="2200"
                android:valueFrom="0.10"
                android:valueTo="0.55"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:valueType="floatType" />
        </aapt:attr>
    </target>

    <!-- Target for Glowing Eyes & Mouth Breathing Animation -->
    <target android:name="glowing_face">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="alpha"
                android:duration="1800"
                android:valueFrom="0.30"
                android:valueTo="1.0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:valueType="floatType" />
        </aapt:attr>
    </target>

</animated-vector>
